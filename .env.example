# ==============================================================================
# Environment Configuration - AI-Powered Mock Interview Platform
# ==============================================================================

# Database Connection (Supabase or local Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_pass@db:5432/ai_mock_interview

# Database Admin Secrets (Used for local compose setup only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=ai_mock_interview

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration (Frontend & Backend)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# API Base URL (Frontend) - Empty for local proxy dev, set to backend domain in production
VITE_API_BASE_URL=

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Supabase Storage Integration
SUPABASE_URL=https://your-project-id.supabase.co/rest/v1/
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-api-key
