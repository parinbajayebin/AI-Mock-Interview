# ==============================================================================
# Environment Configuration - AI-Powered Mock Interview Platform
# ==============================================================================

# 📦 DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# PostgreSQL Connection String. Use 'postgresql+asyncpg' as the dialect.
# Can be local PostgreSQL, a Supabase DB, or a Neon DB (https://neon.tech).
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_pass@localhost:5432/ai_mock_interview

# Database Admin Secrets (Used for local Docker Compose setup only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=ai_mock_interview


# 🤖 AI CORE CONFIGURATION (GEMINI / GROQ / OPENROUTER)
# ------------------------------------------------------------------------------
# Primary LLM provider to use (default: gemini)
LLM_PROVIDER=gemini

# Google Gemini API Settings:
# 👉 Get your FREE API key here: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Groq Settings (Optional alternative):
# 👉 Get your FREE API key here: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter Settings (Optional alternative):
# 👉 Get your API key here: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free


# ⚡ SUPABASE AUTHENTICATION & STORAGE
# ------------------------------------------------------------------------------
# Found under your Supabase Project Settings -> API (https://supabase.com)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Supabase Storage Integration (Backend Access)
# Found under Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here


# 💳 RAZORPAY SUBSCRIPTION GATEWAY (PREMIUM SERVICES)
# ------------------------------------------------------------------------------
# Found in Razorpay Dashboard under Settings -> API Keys (https://dashboard.razorpay.com)
# Use 'rzp_test_...' keys for local development testing
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here


# 🌐 NETWORK & ROUTING SETTINGS
# ------------------------------------------------------------------------------
# Local Frontend URL (React dev server default is http://localhost:5173)
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000
